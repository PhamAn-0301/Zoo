<div class="animal-name">${a.name}</div>
<div class="animal-meta">
<span class="mini-badge ${zoneClass}">${zone}</span>
<span class="mini-badge ${statusClass}">${statusText}</span>
</div>
</div>
`;
                }

               item.onclick = () => {
                    const marker = markerMap[a.id];

                    // 1. Lướt đến vị trí với mức zoom = 1 (hoặc thay bằng map.getZoom() nếu bạn muốn giữ nguyên mức zoom hiện tại không bị giật vào trong)
                    map.flyTo([a.map_y, a.map_x], 1, {
                        animate: true,
                        duration: 1.2 // Lướt đi trong 1.2 giây
                    });

                    // 2. Lắng nghe sự kiện: Đợi bản đồ dừng hẳn hiệu ứng lướt thì mới mở Popup
                    map.once('moveend', () => {
                        marker.openPopup();
                    });
                };
                list.appendChild(item)

            })

        }

        function applyFiltersAndRender() {
            const keyword = String(searchInput?.value || "").trim().toLowerCase();

            let baseItems = combinedItems;
            if (activeQuickFilter === "animal") {
                baseItems = combinedItems.filter((item) => item.kind === "animal");
            } else if (["historical", "toilet", "food", "parking", "utility"].includes(activeQuickFilter)) {
                baseItems = combinedItems.filter(
                    (item) => item.kind === "location" && item.category === activeQuickFilter,
                );
            }

            const filtered = baseItems.filter((item) => {
                if (!keyword) return true;

                if (item.kind === "location") {
                    const locationText = [
                        item.name,
                        item.type,
                        item.summary,
                        item.history,
                        item.value,
                        item.experience,
                        item.visit,
                        String(item.map_x),
                        String(item.map_y),
                    ]
                        .filter(Boolean)
                        .join(" ")
                        .toLowerCase();

                    return locationText.includes(keyword);
                }

                return String(item.name || "").toLowerCase().includes(keyword);
            });

            renderList(filtered);
        }

        filterButtons.forEach((btn) => {
            btn.addEventListener("click", () => {
                activeQuickFilter = btn.dataset.filter || "all";

                filterButtons.forEach((button) => {
                    button.classList.toggle("active", button === btn);
                });

                applyFiltersAndRender();
            });
        });

        applyFiltersAndRender();

        /* search */

        document
            .getElementById("search")
            .addEventListener("input", e => {
                applyFiltersAndRender()

            })
        
          
    </script>

    <script src="shared-nav.js"></script>

</body>

</html>