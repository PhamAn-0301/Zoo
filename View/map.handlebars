<!DOCTYPE html>
<html>

<head>

    <meta charset="utf-8">

    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

    <style>
        /* layout */

        html,
        body {
            margin: 0;
            height: 100%;
            font-family: Arial;
        }

        #map {
            position: fixed;
            top: 0;
            left: 300px;
            right: 0;
            bottom: 0;
        }

        /* sidebar */

        .sidebar {
            position: fixed;
            left: 0;
            top: 0;
            bottom: 0;
            width: 300px;
            background: white;
            box-shadow: 2px 0 10px rgba(0, 0, 0, 0.2);
            z-index: 1000;
            overflow: auto;
        }

        .sidebar-header {
            padding: 15px;
            font-size: 20px;
            font-weight: bold;
            border-bottom: 1px solid #ddd;
        }

        .search-box {
            padding: 10px;
        }

        .search-box input {
            width: 100%;
            padding: 8px;
            border-radius: 6px;
            border: 1px solid #ccc;
        }

        .animal-list {
            padding: 10px;
        }

        .animal-item {
            padding: 8px;
            border-radius: 6px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .animal-item:hover {
            background: #f0f0f0;
        }

        /* popup */

        .popup-card {
            width: 220px;
        }

        .popup-img {
            width: 100%;
            height: 120px;
            object-fit: cover;
            border-radius: 6px;
            margin-bottom: 6px;
        }

        .popup-title {
            font-weight: bold;
        }

        .popup-status {
            font-size: 13px;
            color: #555;
        }
    </style>

</head>

<body>

    <div class="sidebar">

        <div class="sidebar-header">
            Thảo Cầm Viên
        </div>

        <div class="search-box">
            <input id="search" placeholder="Search animal...">
        </div>

        <div class="animal-list" id="animalList">
        </div>

    </div>

    <div id="map"></div>

    <script>

        /* map setup */

        const map = L.map("map", {
            crs: L.CRS.Simple,
            minZoom: -3,
            maxZoom: 2
        })

        const width = 2000
        const height = 1100

        const bounds = [[0, 0], [height, width]]

        L.imageOverlay("/assets1/zoo.jpg", bounds)
            .addTo(map)

        map.fitBounds(bounds)

        /* animals */

        const animals = {{{ animals }}}

        /* icon function */

        function animalIcon(type) {

            let icon = "🐾"

            if (type?.toLowerCase().includes("tiger")) icon = "🐯"
            else if (type?.toLowerCase().includes("elephant")) icon = "🐘"
            else if (type?.toLowerCase().includes("giraffe")) icon = "🦒"
            else if (type?.toLowerCase().includes("lion")) icon = "🦁"
            else if (type?.toLowerCase().includes("bird")) icon = "🦜"

            return L.divIcon({
                html: `<div style="font-size:28px">${icon}</div>`,
                iconSize: [30, 30],
                className: "animal-marker"
            })

        }

        /* markers */

        const markerMap = {}

        let highlightCircle

        animals.forEach(a => {

            const marker = L.marker(
                [a.map_y, a.map_x],
                { icon: animalIcon(a.species) }
            ).addTo(map)

            markerMap[a.id] = marker

            /* hover highlight */

            marker.on("mouseover", () => {

                if (highlightCircle) map.removeLayer(highlightCircle)

                highlightCircle = L.circle(
                    [a.map_y, a.map_x],
                    {
                        radius: 40,
                        color: "#00aaff",
                        weight: 2,
                        fillOpacity: 0.2
                    }
                ).addTo(map)

            })

            marker.on("mouseout", () => {
                if (highlightCircle) map.removeLayer(highlightCircle)
            })

            /* popup */

            marker.bindPopup(`

<div class="popup-card">

<img class="popup-img"
src="${a.image_url || '/images/animal.jpg'}">

<div class="popup-title">
${a.name}
</div>

<div class="popup-status">
Species: ${a.species || "unknown"}<br>
Status: ${a.status || "normal"}
</div>

</div>

`)

        })

        /* sidebar render */

        const list = document.getElementById("animalList")

        function renderList(data) {

            list.innerHTML = ""

            data.forEach(a => {

                const item = document.createElement("div")
                item.className = "animal-item"

                item.innerHTML = `
<span style="font-size:20px">
${animalIcon(a.species).options.html}
</span>
${a.name}
`

                item.onclick = () => {

                    const marker = markerMap[a.id]

                    map.setView(
                        [a.map_y, a.map_x],
                        1
                    )

                    marker.openPopup()

                }

                list.appendChild(item)

            })

        }

        renderList(animals)

        /* search */

        document
            .getElementById("search")
            .addEventListener("input", e => {

                const keyword = e.target.value.toLowerCase()

                const filtered = animals.filter(a =>
                    a.name.toLowerCase().includes(keyword)
                )

                renderList(filtered)

            })

    </script>

</body>

</html>