        function focusAnimalById(animalId) {
            const target = animals.find(a => String(a.id) === String(animalId));
            const marker = markerMap[animalId];
            if (!target || !marker) return;

            const targetZoom = Math.min(Math.max(map.getMinZoom() + 1.1, 1), map.getMaxZoom());

            map.flyTo([target.map_y, target.map_x], targetZoom, {
                duration: 0.8
            });

            marker.openPopup();
            showHighlight([target.map_y, target.map_x], marker, 60);
        }

        const params = new URLSearchParams(window.location.search);
        const focusAnimalId = params.get("animalId");
        if (focusAnimalId) {
            focusAnimalById(focusAnimalId);
        }

        const focusLocationId = params.get("locationId");
        if (focusLocationId && markerMap[focusLocationId]) {
            const target = locations.find((item) => String(item.id) === String(focusLocationId));
            if (target) {
                const targetZoom = Math.min(Math.max(map.getMinZoom() + 1.1, 1), map.getMaxZoom());
                map.flyTo([target.map_y, target.map_x], targetZoom, { duration: 0.8 });
                markerMap[focusLocationId].openPopup();
                showHighlight([target.map_y, target.map_x], markerMap[focusLocationId], 60);
            }
        }

