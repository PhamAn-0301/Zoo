        function normalizeLocationRecord(record) {
            const source = record && typeof record === "object" ? record : {};

            const normalizeText = (value) =>
                String(value || "")
                    .toLowerCase()
                    .normalize("NFD")
                    .replace(/[\u0300-\u036f]/g, "");

            const mergedText = `${source.name || ""} ${source.type || ""} ${source.summary || ""}`;
            const normalized = normalizeText(mergedText);

            let category = "utility";
            if (normalized.includes("di tich")) category = "historical";
            else if (normalized.includes("nha ve sinh")) category = "toilet";
            else if (normalized.includes("am thuc") || normalized.includes("nha an")) category = "food";
            else if (normalized.includes("bai do xe") || normalized.includes("bai gui xe") || normalized.includes("o to")) category = "parking";

            return {
                ...source,
                kind: "location",
                category,
                map_x: Number(source.map_x),
                map_y: Number(source.map_y),
            };
        }

        const locations = locationsRaw
            .map(normalizeLocationRecord)
            .filter((item) => Number.isFinite(item.map_x) && Number.isFinite(item.map_y));

        const combinedItems = [
            ...animals.map((item) => ({ ...item, kind: "animal" })),
            ...locations,
        ];

        /* icon function */

        function animalIcon(type) {

            let icon = "🐾"

            if (type?.toLowerCase().includes("tiger")) icon = "🐯"
            else if (type?.toLowerCase().includes("elephant")) icon = "🐘"
            else if (type?.toLowerCase().includes("giraffe")) icon = "🦒"
            else if (type?.toLowerCase().includes("lion")) icon = "🦁"
            else if (type?.toLowerCase().includes("bird")) icon = "🦜"

            return L.divIcon({
                html: `<div style="font-size:28px">${icon}</div>`,
                iconSize: [1, 1],
                className: "animal-marker"
            })

        }

        /* markers */

        const markerMap = {}

        let highlightCircle

        function showHighlight(latlng, marker, radius = 40) {
            if (highlightCircle) map.removeLayer(highlightCircle);

            highlightCircle = L.circle(latlng, {
                radius,
                color: "#00aaff",
                weight: 2,
                fillOpacity: 0.2,
                interactive: true
            }).addTo(map);

            // Click vao vong tron xanh cung mo popup con vat.
            highlightCircle.on("click", (e) => {
                if (e.originalEvent) {
                    L.DomEvent.stopPropagation(e.originalEvent);
                }
                marker.openPopup();
            });
        }

        function isAnimalActive(statusValue) {
            if (statusValue === true || statusValue === 1) return true;
            if (statusValue === false || statusValue === 0) return false;

            const normalized = String(statusValue ?? "").trim().toLowerCase();

            if (["false", "0", "inactive", "rest", "nghi", "nghi ngoi", "nghỉ", "nghỉ ngơi"].includes(normalized)) {
                return false;
            }

            return ["true", "1", "active", "hoat dong", "hoạt động", "dang hoat dong", "đang hoạt động"].includes(normalized);
        }

        function resolveZoneValue(a) {
            const rawZone = a?.zone ?? a?.Zone ?? a?.khu ?? a?.area ?? a?.zone_id;
            if (rawZone === null || rawZone === undefined || rawZone === "") {
                return null;
            }

            const asNumber = Number(rawZone);
            if (!Number.isNaN(asNumber)) {
                return asNumber;
            }

            const matched = String(rawZone).match(/\d+/);
            if (matched) {
                return Number(matched[0]);
            }

            return String(rawZone).trim();
        }

        function formatZoneLabel(a) {
            if (a?.zoneLabel) return String(a.zoneLabel);
            const zoneValue = resolveZoneValue(a);
            if (zoneValue === null) return "Chua ro khu";
            return typeof zoneValue === "number" ? `Khu ${zoneValue}` : zoneValue;
        }

        function getZoneClassName(a) {
            const zoneValue = resolveZoneValue(a);
            if (typeof zoneValue !== "number") return "";
            if (zoneValue < 1 || zoneValue > 6) return "";
            return `zone-${zoneValue}`;
        }

        function buildAnimalPopup(a) {
            const imageUrl = a.image_url || a.imageUrl || "/images/animal.jpg";
            const species = a.species || a.family || "Chưa cập nhật";
            const zone = formatZoneLabel(a);
            const feedingTime = a.feeding_time || a.feedingTime || "Chưa cập nhật";
            const activeTime = a.active_time || a.activeTime || "Chưa cập nhật";
            const conservation = a.conservation_status || a.conservationStatus || "Chưa cập nhật";

            const active = isAnimalActive(a.status);
            const statusText = active ? "Đang hoạt động" : "Đang nghỉ ngơi";
            const statusClass = active ? "active" : "inactive";

            return `
<div class="popup-card">
<img class="popup-img" src="${imageUrl}" alt="${a.name || "Animal"}">
<div class="popup-title">${a.name || "Chưa cập nhật"}</div>
<div class="popup-meta">
<div><b>Họ:</b> ${species}</div>
<div><b>Khu:</b> ${zone}</div>
<div><b>Bảo tồn:</b> ${conservation}</div>
<div><b>Giờ cho ăn:</b> ${feedingTime}</div>
<div><b>Sinh hoạt:</b> ${activeTime}</div>
</div>
<div class="popup-status"><span class="status-dot ${statusClass}"></span>${statusText}</div>
</div>
`;
        }

        function locationIcon(type) {
            const normalized = String(type || "").toLowerCase();
            let icon = "📍";

            if (normalized.includes("di tích")) icon = "🏛️";
            else if (normalized.includes("bảo tàng")) icon = "🧪";
            else if (normalized.includes("bướm")) icon = "🦋";
            else if (normalized.includes("sách")) icon = "📚";
            else if (normalized.includes("lan")) icon = "🌸";
            else if (normalized.includes("nhà vệ sinh")) icon = "🚻";
            else if (normalized.includes("bãi đỗ xe")) icon = "🅿️";
            else if (normalized.includes("y tế")) icon = "🏥";
            else if (normalized.includes("nhà ăn") || normalized.includes("ẩm thực")) icon = "🍽️";
            else if (normalized.includes("trạm") || normalized.includes("giao thông") || normalized.includes("xe")) icon = "🚉";
            else if (normalized.includes("vui chơi")) icon = "🎠";
            else if (normalized.includes("sự kiện") || normalized.includes("sân khấu")) icon = "🎭";

            return `<div style="font-size:22px;line-height:1">${icon}</div>`;
        }

        function getLocationCategoryLabel(category) {
            if (category === "historical") return "Di tích lịch sử";
            if (category === "toilet") return "Nhà vệ sinh";
            if (category === "food") return "Khu ăn uống";
            if (category === "parking") return "Bãi gửi xe";
            return "Tiện ích";
        }

        function buildLocationPopup(location) {
            const rows = [
                `<div><b>Loại:</b> ${location.type || "Chưa cập nhật"}</div>`,
            ];

            if (location.summary) rows.push(`<div><b>Đặc điểm:</b> ${location.summary}</div>`);
            if (location.status) rows.push(`<div><b>Trạng thái:</b> ${location.status}</div>`);
            if (location.history) rows.push(`<div><b>Lịch sử:</b> ${location.history}</div>`);
            if (location.scale) rows.push(`<div><b>Quy mô:</b> ${location.scale}</div>`);
            if (location.ecology) rows.push(`<div><b>Sinh thái:</b> ${location.ecology}</div>`);
            if (location.value) rows.push(`<div><b>Giá trị:</b> ${location.value}</div>`);
            if (location.experience) rows.push(`<div><b>Trải nghiệm:</b> ${location.experience}</div>`);
            if (location.visit) rows.push(`<div><b>Tham quan:</b> ${location.visit}</div>`);

            const locationStatusText = location.status || "Địa điểm tham quan";
            const isInactiveLocation = String(location.status || "")
                .trim()
                .toLowerCase()
                .includes("ngưng");
            const locationStatusClass = isInactiveLocation ? "inactive" : "active";

            return `
<div class="popup-card">
<div class="popup-title">${location.name || "Địa điểm"}</div>
<div class="popup-meta">
${rows.join("")}
</div>
<div class="popup-status"><span class="status-dot ${locationStatusClass}"></span>${locationStatusText}</div>
</div>
`;
        }

