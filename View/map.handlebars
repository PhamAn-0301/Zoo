<!DOCTYPE html>
<html>

<head>

    <meta charset="utf-8">

    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

    <style>
        :root {
            --sidebar-width: 320px;
            --green-900: #0e3417;
            --green-800: #183c05;
            --green-700: #245f13;
            --green-100: #eaf7e7;
            --green-050: #f6fbf4;
            --text-main: #102118;
            --text-soft: #4f6456;
            --line-soft: #dce8d8;
        }

        html,
        body {
            margin: 0;
            height: 100%;
            font-family: "Be Vietnam Pro", "Segoe UI", sans-serif;
            color: var(--text-main);
        }

        body {
            background: linear-gradient(145deg, #f8fcf7 0%, #ecf5ea 100%);
        }

        #map {
            position: fixed;
            top: 0;
            left: var(--sidebar-width);
            right: 0;
            bottom: 0;
            transition: left 0.28s ease, top 0.28s ease;
        }

        .sidebar {
            position: fixed;
            left: 0;
            top: 0;
            bottom: 0;
            width: var(--sidebar-width);
            z-index: 1000;
            display: flex;
            flex-direction: column;
            background:
                radial-gradient(120% 80% at 0% 0%, rgba(36, 95, 19, 0.14) 0%, rgba(255, 255, 255, 0) 55%),
                linear-gradient(180deg, #fbfefb 0%, #f3f8f2 100%);
            border-right: 1px solid #cfdfcb;
            box-shadow: 8px 0 28px rgba(11, 43, 17, 0.18);
            overflow: hidden;
            transition: transform 0.28s ease, box-shadow 0.28s ease;
        }

        body.sidebar-collapsed .sidebar {
            transform: translateX(calc(-1 * var(--sidebar-width) - 14px));
            box-shadow: none;
        }

        body.sidebar-collapsed #map {
            left: 0;
        }

        .sidebar-header {
            padding: 16px 16px 14px;
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 1px solid var(--line-soft);
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.95) 0%, rgba(247, 252, 246, 0.98) 100%);
            backdrop-filter: blur(6px);
        }

        .back-home {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 38px;
            height: 38px;
            border-radius: 11px;
            text-decoration: none;
            color: #fff;
            background: linear-gradient(135deg, #2f7d1e 0%, #183c05 100%);
            border: 1px solid rgba(255, 255, 255, 0.25);
            box-shadow: 0 8px 16px rgba(24, 60, 5, 0.32);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            flex-shrink: 0;
        }

        .back-home svg {
            width: 22px;
            height: 22px;
        }

        .back-home:hover {
            transform: translateY(-1px);
            box-shadow: 0 10px 18px rgba(24, 60, 5, 0.38);
        }

        .sidebar-title-wrap {
            min-width: 0;
            flex: 1;
        }

        .sidebar-collapse-btn {
            width: 34px;
            height: 34px;
            border-radius: 10px;
            border: 1px solid #cfdfcb;
            background: #ffffff;
            color: #345e2f;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: background-color 0.2s ease, transform 0.2s ease;
            flex-shrink: 0;
        }

        .sidebar-collapse-btn:hover {
            background: #f0f7ee;
            transform: translateY(-1px);
        }

        .sidebar-collapse-btn svg {
            width: 18px;
            height: 18px;
        }

        .sidebar-show-btn {
            position: fixed;
            left: 10px;
            top: 50%;
            transform: translateY(-50%);
            z-index: 1200;
            width: 30px;
            height: 76px;
            border-radius: 999px;
            border: 1px solid rgba(58, 97, 43, 0.18);
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(243, 250, 241, 0.95) 100%);
            color: #2f7d1e;
            box-shadow: 0 10px 20px rgba(22, 55, 24, 0.16);
            display: none;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
            backdrop-filter: blur(3px);
        }

        .sidebar-show-btn:hover {
            transform: translateY(-50%) translateX(1px);
            box-shadow: 0 12px 22px rgba(22, 55, 24, 0.2);
            background: #ffffff;
        }

        .sidebar-show-btn svg {
            width: 18px;
            height: 18px;
        }

        body.sidebar-collapsed .sidebar-show-btn {
            display: inline-flex;
        }

        .sidebar-title {
            margin: 0;
            font-size: 30px;
            line-height: 1;
            letter-spacing: 0.2px;
            color: var(--green-900);
            font-weight: 700;
        }

        .sidebar-sub {
            margin: 5px 0 0;
            font-size: 12px;
            color: var(--text-soft);
            font-weight: 500;
        }

        .search-box {
            padding: 12px 12px 10px;
            position: relative;
        }

        .search-icon {
            position: absolute;
            left: 24px;
            top: 50%;
            transform: translateY(-50%);
            color: #7a8d80;
            pointer-events: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .search-icon svg {
            width: 16px;
            height: 16px;
        }

        .search-box input {
            width: 100%;
            box-sizing: border-box;
            padding: 11px 12px 11px 38px;
            border-radius: 12px;
            border: 1px solid #cadad2;
            background: rgba(255, 255, 255, 0.94);
            font-size: 14px;
            font-weight: 500;
            color: var(--text-main);
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

        .search-box input:focus {
            outline: none;
            border-color: #4f8c3f;
            box-shadow: 0 0 0 4px rgba(79, 140, 63, 0.15);
        }

        .quick-filters {
            padding: 0 12px 8px;
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .quick-filter-btn {
            border: 1px solid #cde0c7;
            background: #f4faf3;
            color: #2f4738;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 600;
            padding: 6px 11px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .quick-filter-btn:hover {
            border-color: #9dc78f;
            background: #ecf7e9;
        }

        .quick-filter-btn.active {
            border-color: #4f8c3f;
            background: #4f8c3f;
            color: #fff;
            box-shadow: 0 6px 12px rgba(26, 86, 31, 0.2);
        }

        .quick-action-btn {
            border: 1px solid #b7cdb0;
            background: #eef7eb;
            color: #2f5f32;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 700;
            padding: 6px 11px;
            cursor: pointer;
        }

        .badge-modal {
            position: fixed;
            inset: 0;
            background: rgba(11, 27, 14, 0.42);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 2200;
            padding: 14px;
        }

        .badge-modal.open {
            display: flex;
        }

        .badge-modal-card {
            width: min(420px, 100%);
            max-height: 75vh;
            overflow: auto;
            border-radius: 16px;
            border: 1px solid #cadec8;
            background:
                radial-gradient(120% 80% at 15% -20%, rgba(111, 193, 96, 0.22) 0%, rgba(255, 255, 255, 0) 60%),
                linear-gradient(180deg, #ffffff 0%, #f4faf2 100%);
            box-shadow: 0 20px 40px rgba(12, 41, 17, 0.26);
            padding: 14px;
        }

        .badge-modal-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 12px;
            padding: 10px 10px 8px;
            border-radius: 12px;
            border: 1px solid #cfe1cb;
            background: linear-gradient(120deg, #f7fcf5 0%, #edf8ea 100%);
        }

        .badge-modal-title {
            margin: 0;
            font-size: 24px;
            color: #15361c;
            letter-spacing: 0.2px;
        }

        .badge-modal-sub {
            margin-top: 2px;
            font-size: 12px;
            color: #4f6a59;
            font-weight: 600;
        }

        .badge-modal-close {
            border: 1px solid #c7d9c2;
            background: #ffffff;
            color: #335c2f;
            border-radius: 10px;
            width: 32px;
            height: 32px;
            cursor: pointer;
            font-size: 20px;
            line-height: 1;
        }

        .badge-list {
            display: grid;
            gap: 8px;
        }

        .badge-summary {
            display: flex;
            gap: 8px;
            margin-bottom: 10px;
            flex-wrap: wrap;
        }

        .badge-summary-chip {
            border: 1px solid #c7dbc3;
            border-radius: 999px;
            padding: 6px 10px;
            font-size: 12px;
            font-weight: 700;
            color: #2a5b35;
            background: #eff8ec;
        }

        .badge-item {
            border: 1px solid #d5e3d2;
            border-radius: 12px;
            padding: 10px;
            background: linear-gradient(150deg, #fcfffb 0%, #f3f9f1 100%);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
        }

        .badge-item:hover {
            transform: translateY(-1px);
            box-shadow: 0 10px 18px rgba(20, 56, 27, 0.12);
            border-color: #bdd7b7;
        }

        .badge-item.locked {
            opacity: 0.75;
            filter: grayscale(0.18);
        }

        .badge-item.unlocked {
            border-color: #91c786;
            background:
                radial-gradient(80% 70% at 0% 0%, rgba(124, 205, 109, 0.28) 0%, rgba(255, 255, 255, 0) 65%),
                linear-gradient(150deg, #fbfff9 0%, #eef9e9 100%);
        }

        .badge-item-main {
            display: flex;
            align-items: flex-start;
            gap: 10px;
            min-width: 0;
        }

        .badge-item-icon {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            border: 1px solid #c7dbc3;
            background: #f4faf2;
            flex: 0 0 auto;
            margin-top: 1px;
        }

        .badge-item.unlocked .badge-item-icon {
            border-color: #8bc37f;
            background: linear-gradient(140deg, #dff3d8 0%, #bfe8b5 100%);
        }

        .badge-item-name {
            font-size: 24px;
            font-weight: 700;
            color: #1c3b24;
            line-height: 1.15;
        }

        .badge-item-desc {
            margin-top: 2px;
            font-size: 16px;
            color: #587062;
        }

        .badge-item-state {
            font-size: 10px;
            font-weight: 700;
            border-radius: 999px;
            padding: 4px 8px;
            border: 1px solid #c9d6cd;
            background: #f2f6f3;
            color: #5b6d62;
            white-space: nowrap;
        }

        .badge-item.unlocked .badge-item-state {
            border-color: #99c893;
            background: #e6f6e1;
            color: #216a30;
        }

        .badge-item.locked .badge-item-state {
            border-color: #cfd6d2;
            background: #f0f3f1;
            color: #7a8880;
        }

        .reward-popup {
            position: fixed;
            left: 50%;
            top: 26px;
            transform: translateX(-50%);
            z-index: 2300;
            display: none;
            width: min(420px, calc(100vw - 20px));
            background: linear-gradient(145deg, #2d7f24 0%, #174f11 100%);
            color: #fff;
            border-radius: 14px;
            box-shadow: 0 16px 30px rgba(12, 46, 16, 0.36);
            border: 1px solid rgba(255, 255, 255, 0.28);
            padding: 12px 12px 10px;
        }

        .reward-popup.open {
            display: block;
            animation: reward-slide-in 0.22s ease-out;
        }

        .reward-popup-title {
            font-size: 15px;
            font-weight: 700;
            margin-bottom: 6px;
        }

        .reward-popup-list {
            margin: 0;
            padding-left: 18px;
            font-size: 13px;
            line-height: 1.4;
        }

        .reward-popup-close {
            margin-top: 8px;
            border: 1px solid rgba(255, 255, 255, 0.4);
            background: rgba(255, 255, 255, 0.15);
            color: #fff;
            border-radius: 10px;
            padding: 6px 10px;
            font-weight: 700;
            cursor: pointer;
        }

        .game-complete-modal {
            position: fixed;
            inset: 0;
            z-index: 2400;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 14px;
            background: rgba(8, 24, 12, 0.5);
        }

        .game-complete-modal.open {
            display: flex;
        }

        .game-complete-card {
            width: min(460px, 100%);
            border-radius: 16px;
            border: 1px solid #b9d9b2;
            padding: 18px 16px;
            background:
                radial-gradient(100% 70% at 50% -20%, rgba(149, 220, 129, 0.3) 0%, rgba(255, 255, 255, 0) 65%),
                linear-gradient(180deg, #ffffff 0%, #eef9ea 100%);
            box-shadow: 0 24px 40px rgba(12, 44, 17, 0.34);
            text-align: center;
        }

        .game-complete-title {
            font-size: 26px;
            font-weight: 800;
            color: #184222;
            margin: 0 0 8px;
        }

        .game-complete-message {
            margin: 0;
            font-size: 16px;
            line-height: 1.55;
            color: #2f4f39;
            font-weight: 600;
        }

        .game-complete-close {
            margin-top: 14px;
            border: none;
            border-radius: 10px;
            padding: 9px 14px;
            font-size: 14px;
            font-weight: 700;
            color: #ffffff;
            background: linear-gradient(135deg, #2f7d1e 0%, #1a5c10 100%);
            cursor: pointer;
        }

        @keyframes reward-slide-in {
            from {
                opacity: 0;
                transform: translateX(-50%) translateY(-8px);
            }
            to {
                opacity: 1;
                transform: translateX(-50%) translateY(0);
            }
        }

        .mini-badge.cat-historical {
            border-color: #b8c8a2;
            background: #f1f6e7;
            color: #445b2c;
        }

        .mini-badge.cat-toilet {
            border-color: #b7cdd8;
            background: #eef7fb;
            color: #2f5668;
        }

        .mini-badge.cat-food {
            border-color: #dec7a7;
            background: #fdf4ea;
            color: #6f4a1f;
        }

        .mini-badge.cat-parking {
            border-color: #c8c5e1;
            background: #f3f1fb;
            color: #3f3d71;
        }

        .mini-badge.cat-utility {
            border-color: #c8d7c8;
            background: #f2f8f2;
            color: #37553a;
        }

        .animal-list {
            flex: 1;
            overflow: auto;
            padding: 8px 10px 14px;
        }

        .animal-item {
            display: flex;
            align-items: center;
            gap: 10px;
            width: 100%;
            margin: 7px 0;
            padding: 10px 12px;
            border-radius: 14px;
            cursor: pointer;
            border: 1px solid transparent;
            background: rgba(255, 255, 255, 0.82);
            transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
            box-sizing: border-box;
        }

        .animal-item:hover {
            transform: translateY(-2px);
            border-color: #c7dfc0;
            box-shadow: 0 10px 18px rgba(34, 75, 16, 0.1);
            background: #ffffff;
        }

        .animal-icon {
            width: 34px;
            height: 34px;
            border-radius: 10px;
            background: linear-gradient(145deg, #eff9ed 0%, #dff1da 100%);
            border: 1px solid #cfe5c8;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .animal-main {
            min-width: 0;
            flex: 1;
        }

        .animal-name {
            font-size: 18px;
            font-weight: 700;
            letter-spacing: 0.1px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            color: #122a17;
        }

        .animal-meta {
            margin-top: 4px;
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
        }

        .mini-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: 11px;
            padding: 3px 8px;
            border-radius: 999px;
            border: 1px solid #cde0c7;
            color: #3e5d49;
            background: #f4faf3;
            line-height: 1;
        }

        .mini-badge.zone-1 {
            background: #cfd3cf;
            border-color: #a8afa9;
            color: #2f3731;
        }

        .mini-badge.zone-2 {
            background: #cfd8bf;
            border-color: #a8b395;
            color: #33402a;
        }

        .mini-badge.zone-3 {
            background: #ece2bf;
            border-color: #c5ba93;
            color: #464025;
        }

        .mini-badge.zone-4 {
            background: #efcfbe;
            border-color: #c9a695;
            color: #4a352b;
        }

        .mini-badge.zone-5 {
            background: #dcc7da;
            border-color: #b49eb1;
            color: #473445;
        }

        .mini-badge.zone-6 {
            background: #bfd5c3;
            border-color: #97ae9c;
            color: #2f4234;
        }

        .mini-badge.status-on {
            border-color: #8ec78e;
            color: #1c6d2e;
            background: #ecf9ef;
        }

        .mini-badge.status-off {
            border-color: #d2d9d1;
            color: #66746b;
            background: #f6f8f5;
        }

        .mini-badge.checkin-on {
            border-color: #96ca8d;
            color: #1e6f31;
            background: #e8f8e4;
        }

        .mini-badge.checkin-off {
            border-color: #d8dfd7;
            color: #67756d;
            background: #f5f7f5;
        }

        .empty-state {
            margin: 16px 8px;
            border-radius: 14px;
            border: 1px dashed #c8d8c4;
            background: rgba(255, 255, 255, 0.75);
            padding: 14px;
            text-align: center;
            color: #557060;
            font-size: 13px;
            font-weight: 500;
        }

        .animal-list::-webkit-scrollbar {
            width: 8px;
        }

        .animal-list::-webkit-scrollbar-track {
            background: transparent;
        }

        .animal-list::-webkit-scrollbar-thumb {
            background: linear-gradient(180deg, #b3cdaa 0%, #8fb984 100%);
            border-radius: 999px;
            border: 2px solid #eef6eb;
        }

        /* popup */
        .animal-popup .leaflet-popup-content-wrapper {
            border-radius: 14px;
            box-shadow: 0 12px 26px rgba(0, 0, 0, 0.2);
            animation: popup-in 0.22s ease-out;
        }

        .animal-popup .leaflet-popup-content {
            margin: 10px;
        }

        .popup-card {
            width: 250px;
        }

        .popup-img {
            width: 100%;
            height: 130px;
            object-fit: cover;
            border-radius: 10px;
            margin-bottom: 8px;
        }

        .popup-title {
            font-weight: 700;
            font-size: 16px;
            margin-bottom: 6px;
            color: #1f2a2b;
        }

        .popup-meta {
            font-size: 13px;
            color: #4d5b5c;
            display: grid;
            gap: 4px;
            margin-bottom: 8px;
        }

        .popup-status {
            font-size: 13px;
            display: flex;
            align-items: center;
            gap: 6px;
            color: #2f3a3b;
            font-weight: 600;
            margin-bottom: 10px;
        }

        .popup-checkin-btn {
            width: 100%;
            border: none;
            border-radius: 10px;
            padding: 9px 12px;
            font-size: 13px;
            font-weight: 700;
            background: linear-gradient(135deg, #2f7d1e 0%, #1c5a10 100%);
            color: #ffffff;
            cursor: pointer;
            transition: transform 0.2s ease, opacity 0.2s ease;
        }

        .popup-checkin-btn:hover {
            transform: translateY(-1px);
        }

        .popup-checkin-btn:disabled {
            background: #dce6d9;
            color: #6f7c73;
            cursor: not-allowed;
            transform: none;
        }

        .popup-actions {
            display: grid;
            grid-template-columns: 1fr;
            gap: 8px;
        }

        .popup-route-btn {
            width: 100%;
            border: 1px solid #bad3b4;
            border-radius: 10px;
            padding: 9px 12px;
            font-size: 13px;
            font-weight: 700;
            background: #f3fbf1;
            color: #1f5f14;
            cursor: pointer;
            transition: transform 0.2s ease, background-color 0.2s ease;
        }

        .popup-route-btn:hover {
            transform: translateY(-1px);
            background: #e8f6e5;
        }

        .status-dot {
            width: 10px;
            height: 10px;
            border-radius: 999px;
            display: inline-block;
            box-shadow: 0 0 0 2px rgba(0, 0, 0, 0.08);
        }

        .status-dot.active {
            background: #17b26a;
        }

        .status-dot.inactive {
            background: #9aa4ad;
        }

        .route-panel {
            position: fixed;
            right: 14px;
            top: 14px;
            width: min(390px, calc(100vw - 20px));
            max-height: calc(100vh - 28px);
            overflow: auto;
            z-index: 2100;
            border-radius: 22px;
            border: 1px solid #d5e7d8;
            background:
                radial-gradient(100% 80% at 90% 0%, rgba(162, 230, 185, 0.35) 0%, rgba(255, 255, 255, 0) 45%),
                linear-gradient(180deg, #ffffff 0%, #f3faf4 100%);
            box-shadow: 0 24px 42px rgba(11, 40, 15, 0.3);
            display: none;
        }

        .route-panel.open {
            display: block;
            animation: popup-in 0.2s ease-out;
        }

        .route-panel-head {
            padding: 15px 15px 12px;
            border-bottom: 1px solid #e1ede3;
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 8px;
        }

        .route-panel-title {
            margin: 0;
            font-size: 28px;
            font-weight: 800;
