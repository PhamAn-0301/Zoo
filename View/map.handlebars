<!DOCTYPE html>
<html>

<head>

    <meta charset="utf-8">

    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

    <style>
        :root {
            --sidebar-width: 320px;
            --green-900: #0e3417;
            --green-800: #183c05;
            --green-700: #245f13;
            --green-100: #eaf7e7;
            --green-050: #f6fbf4;
            --text-main: #102118;
            --text-soft: #4f6456;
            --line-soft: #dce8d8;
        }

        html,
        body {
            margin: 0;
            height: 100%;
            font-family: "Be Vietnam Pro", "Segoe UI", sans-serif;
            color: var(--text-main);
        }

        body {
            background: linear-gradient(145deg, #f8fcf7 0%, #ecf5ea 100%);
        }

        #map {
            position: fixed;
            top: 0;
            left: var(--sidebar-width);
            right: 0;
            bottom: 0;
            transition: left 0.28s ease, top 0.28s ease;
        }

        .sidebar {
            position: fixed;
            left: 0;
            top: 0;
            bottom: 0;
            width: var(--sidebar-width);
            z-index: 1000;
            display: flex;
            flex-direction: column;
            background:
                radial-gradient(120% 80% at 0% 0%, rgba(36, 95, 19, 0.14) 0%, rgba(255, 255, 255, 0) 55%),
                linear-gradient(180deg, #fbfefb 0%, #f3f8f2 100%);
            border-right: 1px solid #cfdfcb;
            box-shadow: 8px 0 28px rgba(11, 43, 17, 0.18);
            overflow: hidden;
            transition: transform 0.28s ease, box-shadow 0.28s ease;
        }

        body.sidebar-collapsed .sidebar {
            transform: translateX(calc(-1 * var(--sidebar-width) - 14px));
            box-shadow: none;
        }

        body.sidebar-collapsed #map {
            left: 0;
        }

        .sidebar-header {
            padding: 16px 16px 14px;
            display: flex;
            align-items: center;
            gap: 12px;
            border-bottom: 1px solid var(--line-soft);
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.95) 0%, rgba(247, 252, 246, 0.98) 100%);
            backdrop-filter: blur(6px);
        }

        .back-home {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 38px;
            height: 38px;
            border-radius: 11px;
            text-decoration: none;
            color: #fff;
            background: linear-gradient(135deg, #2f7d1e 0%, #183c05 100%);
            border: 1px solid rgba(255, 255, 255, 0.25);
            box-shadow: 0 8px 16px rgba(24, 60, 5, 0.32);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            flex-shrink: 0;
        }

        .back-home svg {
            width: 22px;
            height: 22px;
        }

        .back-home:hover {
            transform: translateY(-1px);
            box-shadow: 0 10px 18px rgba(24, 60, 5, 0.38);
        }

        .sidebar-title-wrap {
            min-width: 0;
            flex: 1;
        }

        .sidebar-collapse-btn {
            width: 34px;
            height: 34px;
            border-radius: 10px;
            border: 1px solid #cfdfcb;
            background: #ffffff;
            color: #345e2f;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: background-color 0.2s ease, transform 0.2s ease;
            flex-shrink: 0;
        }

        .sidebar-collapse-btn:hover {
            background: #f0f7ee;
            transform: translateY(-1px);
        }

        .sidebar-collapse-btn svg {
            width: 18px;
            height: 18px;
        }

        .sidebar-show-btn {
            position: fixed;
            left: 10px;
            top: 50%;
            transform: translateY(-50%);
            z-index: 1200;
            width: 30px;
            height: 76px;
            border-radius: 999px;
            border: 1px solid rgba(58, 97, 43, 0.18);
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(243, 250, 241, 0.95) 100%);
            color: #2f7d1e;
            box-shadow: 0 10px 20px rgba(22, 55, 24, 0.16);
            display: none;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
            backdrop-filter: blur(3px);
        }

        .sidebar-show-btn:hover {
            transform: translateY(-50%) translateX(1px);
            box-shadow: 0 12px 22px rgba(22, 55, 24, 0.2);
            background: #ffffff;
        }

        .sidebar-show-btn svg {
            width: 18px;
            height: 18px;
        }

        body.sidebar-collapsed .sidebar-show-btn {
            display: inline-flex;
        }

        .sidebar-title {
            margin: 0;
            font-size: 30px;
            line-height: 1;
            letter-spacing: 0.2px;
            color: var(--green-900);
            font-weight: 700;
        }

        .sidebar-sub {
            margin: 5px 0 0;
            font-size: 12px;
            color: var(--text-soft);
            font-weight: 500;
        }

        .search-box {
            padding: 12px 12px 10px;
            position: relative;
        }

        .search-icon {
            position: absolute;
            left: 24px;
            top: 50%;
            transform: translateY(-50%);
            color: #7a8d80;
            pointer-events: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .search-icon svg {
            width: 16px;
            height: 16px;
        }

        .search-box input {
            width: 100%;
            box-sizing: border-box;
            padding: 11px 12px 11px 38px;
            border-radius: 12px;
            border: 1px solid #cadad2;
            background: rgba(255, 255, 255, 0.94);
            font-size: 14px;
            font-weight: 500;
            color: var(--text-main);
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

        .search-box input:focus {
            outline: none;
            border-color: #4f8c3f;
            box-shadow: 0 0 0 4px rgba(79, 140, 63, 0.15);
        }

        .quick-filters {
            padding: 0 12px 8px;
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .quick-filter-btn {
            border: 1px solid #cde0c7;
            background: #f4faf3;
            color: #2f4738;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 600;
            padding: 6px 11px;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .quick-filter-btn:hover {
            border-color: #9dc78f;
            background: #ecf7e9;
        }

        .quick-filter-btn.active {
            border-color: #4f8c3f;
            background: #4f8c3f;
            color: #fff;
            box-shadow: 0 6px 12px rgba(26, 86, 31, 0.2);
        }

        .mini-badge.cat-historical {
            border-color: #b8c8a2;
            background: #f1f6e7;
            color: #445b2c;
        }

        .mini-badge.cat-toilet {
            border-color: #b7cdd8;
            background: #eef7fb;
            color: #2f5668;
        }

        .mini-badge.cat-food {
            border-color: #dec7a7;
            background: #fdf4ea;
            color: #6f4a1f;
        }

        .mini-badge.cat-parking {
            border-color: #c8c5e1;
            background: #f3f1fb;
            color: #3f3d71;
        }

        .mini-badge.cat-utility {
            border-color: #c8d7c8;
            background: #f2f8f2;
            color: #37553a;
        }

        .animal-list {
            flex: 1;
            overflow: auto;
            padding: 8px 10px 14px;
        }

        .animal-item {
            display: flex;
            align-items: center;
            gap: 10px;
            width: 100%;
            margin: 7px 0;
            padding: 10px 12px;
            border-radius: 14px;
            cursor: pointer;
            border: 1px solid transparent;
            background: rgba(255, 255, 255, 0.82);
            transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
            box-sizing: border-box;
        }

        .animal-item:hover {
            transform: translateY(-2px);
            border-color: #c7dfc0;
            box-shadow: 0 10px 18px rgba(34, 75, 16, 0.1);
            background: #ffffff;
        }

        .animal-icon {
            width: 34px;
            height: 34px;
            border-radius: 10px;
            background: linear-gradient(145deg, #eff9ed 0%, #dff1da 100%);
            border: 1px solid #cfe5c8;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .animal-main {
            min-width: 0;
            flex: 1;
        }

        .animal-name {
            font-size: 18px;
            font-weight: 700;
            letter-spacing: 0.1px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            color: #122a17;
        }

        .animal-meta {
            margin-top: 4px;
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
        }

        .mini-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: 11px;
            padding: 3px 8px;
            border-radius: 999px;
            border: 1px solid #cde0c7;
            color: #3e5d49;
            background: #f4faf3;
            line-height: 1;
        }

        .mini-badge.zone-1 {
            background: #cfd3cf;
            border-color: #a8afa9;
            color: #2f3731;
        }

        .mini-badge.zone-2 {
            background: #cfd8bf;
            border-color: #a8b395;
            color: #33402a;
        }

        .mini-badge.zone-3 {
            background: #ece2bf;
            border-color: #c5ba93;
            color: #464025;
        }

        .mini-badge.zone-4 {
            background: #efcfbe;
            border-color: #c9a695;
            color: #4a352b;
        }

        .mini-badge.zone-5 {
            background: #dcc7da;
            border-color: #b49eb1;
            color: #473445;
        }

        .mini-badge.zone-6 {
            background: #bfd5c3;
            border-color: #97ae9c;
            color: #2f4234;
        }

        .mini-badge.status-on {
            border-color: #8ec78e;
            color: #1c6d2e;
            background: #ecf9ef;
        }

        .mini-badge.status-off {
            border-color: #d2d9d1;
            color: #66746b;
            background: #f6f8f5;
        }

        .empty-state {
            margin: 16px 8px;
            border-radius: 14px;
            border: 1px dashed #c8d8c4;
            background: rgba(255, 255, 255, 0.75);
            padding: 14px;
            text-align: center;
            color: #557060;
            font-size: 13px;
            font-weight: 500;
        }

        .animal-list::-webkit-scrollbar {
            width: 8px;
        }

        .animal-list::-webkit-scrollbar-track {
            background: transparent;
        }

        .animal-list::-webkit-scrollbar-thumb {
            background: linear-gradient(180deg, #b3cdaa 0%, #8fb984 100%);
            border-radius: 999px;
            border: 2px solid #eef6eb;
        }

        /* popup */
        .animal-popup .leaflet-popup-content-wrapper {
            border-radius: 14px;
            box-shadow: 0 12px 26px rgba(0, 0, 0, 0.2);
            animation: popup-in 0.22s ease-out;
        }

        .animal-popup .leaflet-popup-content {
            margin: 10px;
        }

        .popup-card {
            width: 250px;
        }

        .popup-img {
            width: 100%;
            height: 130px;
            object-fit: cover;
            border-radius: 10px;
            margin-bottom: 8px;
        }

        .popup-title {
            font-weight: 700;
            font-size: 16px;
            margin-bottom: 6px;
            color: #1f2a2b;
        }

        .popup-meta {
            font-size: 13px;
            color: #4d5b5c;
            display: grid;
            gap: 4px;
            margin-bottom: 8px;
        }

        .popup-status {
            font-size: 13px;
            display: flex;
            align-items: center;
            gap: 6px;
            color: #2f3a3b;
            font-weight: 600;
        }

        .status-dot {
            width: 10px;
            height: 10px;
            border-radius: 999px;
            display: inline-block;
            box-shadow: 0 0 0 2px rgba(0, 0, 0, 0.08);
        }

        .status-dot.active {
            background: #17b26a;
        }

        .status-dot.inactive {
            background: #9aa4ad;
        }

        @keyframes popup-in {
            from {
                opacity: 0;
                transform: translateY(10px) scale(0.97);
            }
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }

        @media (max-width: 900px) {
            :root {
                --sidebar-width: 100%;
            }

            .sidebar {
                height: 50%;
                bottom: auto;
                border-right: none;
                border-bottom: 1px solid #cfdfcb;
                box-shadow: 0 6px 22px rgba(11, 43, 17, 0.2);
            }

            #map {
                left: 0;
                top: 50%;
            }

            body.sidebar-collapsed .sidebar {
                transform: translateY(calc(-100% - 14px));
            }

            body.sidebar-collapsed #map {
                top: 0;
            }

            .sidebar-show-btn {
                left: 8px;
                top: 50%;
                width: 28px;
                height: 72px;
            }

            .sidebar-header {
                padding: 12px 12px 10px;
                gap: 8px;
            }

            .sidebar-title {
                font-size: 24px;
            }

            .back-home {
                width: 34px;
                height: 34px;
                border-radius: 10px;
            }

            .back-home svg {
                width: 20px;
                height: 20px;
            }

            .sidebar-collapse-btn {
                width: 32px;
                height: 32px;
            }

            .search-box {
                padding: 10px 10px 8px;
            }

            .search-icon {
                left: 20px;
            }

            .search-box input {
                padding: 10px 11px 10px 36px;
                font-size: 13px;
                border-radius: 11px;
            }

            .quick-filters {
                padding: 0 10px 8px;
                flex-wrap: nowrap;
                overflow-x: auto;
                -webkit-overflow-scrolling: touch;
                scrollbar-width: none;
            }

            .quick-filters::-webkit-scrollbar {
                display: none;
            }

            .quick-filter-btn {
                flex: 0 0 auto;
                font-size: 11px;
                padding: 5px 10px;
                white-space: nowrap;
            }

            .animal-list {
                padding: 6px 8px 10px;
            }

            .animal-item {
                margin: 5px 0;
                padding: 8px 10px;
                border-radius: 12px;
                gap: 8px;
            }

            .animal-icon {
                width: 30px;
                height: 30px;
                border-radius: 9px;
            }

            .animal-name {
                font-size: 15px;
            }

            .animal-meta {
                margin-top: 3px;
                gap: 5px;
            }

            .mini-badge {
                font-size: 10px;
                padding: 3px 7px;
            }

            .empty-state {
                margin: 10px 6px;
                padding: 11px;
                font-size: 12px;
            }
        }

        @media (max-width: 520px) {
            .sidebar {
                height: 56%;
            }

            #map {
                top: 56%;
            }

            .sidebar-title {
                font-size: 21px;
            }

            .animal-name {
                font-size: 14px;
            }

            .quick-filter-btn {
                font-size: 10px;
                padding: 4px 9px;
            }

            .mini-badge {
                font-size: 9.5px;
                padding: 2px 6px;
            }
        }
    </style>

</head>

<body>

    <div class="sidebar">

        <div class="sidebar-header">
            <a class="back-home" href="/" title="Quay lại trang chủ" aria-label="Quay lại trang chủ">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M15 5L8 12L15 19" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </a>
            <div class="sidebar-title-wrap">
                <h1 class="sidebar-title">Bản Đồ </h1>
                
            </div>
            <button class="sidebar-collapse-btn" id="hideSidebarBtn" title="Thu gọn thanh bên" aria-label="Thu gọn thanh bên">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M14.5 5L8 12L14.5 19" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </button>
        </div>

        <div class="search-box">
            <span class="search-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"></circle>
                    <path d="M20 20L16.65 16.65" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
                </svg>
            </span>
            <input id="search" placeholder="Tìm động vật, địa điểm...">
        </div>

        <div class="quick-filters" id="quickFilters">
            <button class="quick-filter-btn active" data-filter="all" type="button">Tất cả</button>
            <button class="quick-filter-btn" data-filter="animal" type="button">Động vật</button>
            <button class="quick-filter-btn" data-filter="historical" type="button">Di tích lịch sử</button>
            <button class="quick-filter-btn" data-filter="toilet" type="button">Nhà vệ sinh</button>
            <button class="quick-filter-btn" data-filter="food" type="button">Khu ăn uống</button>
            <button class="quick-filter-btn" data-filter="parking" type="button">Bãi gửi xe</button>
            <button class="quick-filter-btn" data-filter="utility" type="button">Tiện ích</button>
        </div>

        <div class="animal-list" id="animalList">
        </div>

    </div>

    <button class="sidebar-show-btn" id="showSidebarBtn" title="Mở thanh bên" aria-label="Mở thanh bên">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M9.5 5L16 12L9.5 19" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
    </button>

    <div id="map"></div>

    <script>

        /* map setup */

     /* map setup */
       /* map setup */
        const width = 2000;
        const height = 1100;
        const bounds = [[0, 0], [height, width]];
        const SIDEBAR_STATE_KEY = "zoo-map-sidebar-collapsed";

        // Khởi tạo map, tạm thời chưa set minZoom
        const map = L.map("map", {
            crs: L.CRS.Simple,
            maxZoom: 2,
            zoomSnap: 0.1, // Bắt buộc phải có để mức zoom tính toán (số lẻ) hoạt động mượt
            maxBounds: bounds,
            maxBoundsViscosity: 1.0 // Không cho kéo nảy ra ngoài viền ảnh
        });

        const hideSidebarBtn = document.getElementById("hideSidebarBtn");
        const showSidebarBtn = document.getElementById("showSidebarBtn");

        function setSidebarCollapsed(collapsed) {
            document.body.classList.toggle("sidebar-collapsed", collapsed);
            localStorage.setItem(SIDEBAR_STATE_KEY, collapsed ? "1" : "0");

            setTimeout(() => {
                map.invalidateSize();
            }, 300);
        }

        const savedSidebarState = localStorage.getItem(SIDEBAR_STATE_KEY) === "1";
        if (savedSidebarState) {
            setSidebarCollapsed(true);
        }

        hideSidebarBtn.addEventListener("click", () => {
            setSidebarCollapsed(true);
        });

        showSidebarBtn.addEventListener("click", () => {
            setSidebarCollapsed(false);
        });

        L.imageOverlay("/assets1/zoo2.jpg", bounds).addTo(map);

        // Hàm tự động tính toán minZoom để ảnh luôn FULL khung bên phải
        function updateMinZoom() {
            const mapContainer = document.getElementById("map");

            // Tính tỷ lệ giữa khung chứa bản đồ và kích thước thật của ảnh
            const scaleX = mapContainer.clientWidth / width;
            const scaleY = mapContainer.clientHeight / height;

            // Math.max giúp ảnh luôn phủ kín viền (cover). 
            // Không bao giờ để lộ khoảng trắng dù màn hình tỷ lệ nào.
            const scale = Math.max(scaleX, scaleY);

            // Đổi từ tỷ lệ (scale) sang mức zoom của Leaflet (hệ số logarit cơ số 2)
            const minZoom = Math.log2(scale);

            // Cập nhật minZoom mới cho bản đồ
            map.setMinZoom(minZoom);
        }

        // Chạy hàm tính toán khi vừa load trang
        updateMinZoom();

        // Căn giữa bản đồ ở mức zoom nhỏ nhất vừa tính toán
        map.setView([height / 2, width / 2], map.getMinZoom());

        // Tự động tính toán lại nếu người dùng thay đổi kích thước cửa sổ trình duyệt
        window.addEventListener("resize", () => {
            updateMinZoom();
        });

        /* animals */

        const animalsRaw = {{{ animals }}}

        function normalizeAnimalRecord(record) {
            const source = record && typeof record === "object" ? record : {};
            const normalizedKeys = {};

            Object.keys(source).forEach((key) => {
                normalizedKeys[String(key).trim().toLowerCase()] = source[key];
            });

            const zoneValue =
                source.zone ??
                source.Zone ??
                source.zone_id ??
                source.zoneId ??
                source.khu ??
                normalizedKeys.zone ??
                normalizedKeys.zone_id ??
                normalizedKeys.zoneid ??
                normalizedKeys.khu;

            const zoneLabelValue =
                source.zoneLabel ??
                source.zone_label ??
                normalizedKeys.zonelabel ??
                normalizedKeys.zone_label;

            const statusValue =
                source.status ??
                source.Status ??
                normalizedKeys.status;

            const mapX =
                source.map_x ??
                source.mapX ??
                normalizedKeys.map_x ??
                normalizedKeys.mapx;

            const mapY =
                source.map_y ??
                source.mapY ??
                normalizedKeys.map_y ??
                normalizedKeys.mapy;

            return {
                ...source,
                zone: zoneValue,
                zoneLabel: zoneLabelValue,
                status: statusValue,
                map_x: Number(mapX),
                map_y: Number(mapY),
            };
        }

        const animals = Array.isArray(animalsRaw)
            ? animalsRaw.map(normalizeAnimalRecord).filter(a => Number.isFinite(a.map_x) && Number.isFinite(a.map_y))
            : [];

        const locationsRaw = [
            {
                id: "loc-nhan-huong",
                name: "Di tích quán Nhan Hương",
                map_x: 1688,
                map_y: 133,
