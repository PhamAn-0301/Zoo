            if (checkinButton) {
                checkinButton.addEventListener("click", async () => {
                    const targetId = checkinButton.getAttribute("data-checkin-id");
                    if (!targetId) return;

                    checkinButton.disabled = true;
                    await checkinAnimalById(targetId);
                });
            }

            if (routeButton) {
                routeButton.addEventListener("click", () => {
                    const targetAnimalId = routeButton.getAttribute("data-route-animal-id");
                    if (!targetAnimalId) return;
                    openRouteForAnimalById(targetAnimalId);
                });
            }
        });

        function focusAnimalById(animalId) {
            const target = animals.find(a => String(a.id) === String(animalId));
            const marker = markerMap[animalId];
            if (!target || !marker) return;

            const targetZoom = Math.min(Math.max(map.getMinZoom() + 1.1, 1), map.getMaxZoom());

            map.flyTo([target.map_y, target.map_x], targetZoom, {
                duration: 0.8
            });

            marker.openPopup();
            showHighlight([target.map_y, target.map_x], marker, 60);
        }

        const params = new URLSearchParams(window.location.search);
        const focusAnimalId = params.get("animalId");
        if (focusAnimalId) {
            focusAnimalById(focusAnimalId);
        }

        const focusLocationId = params.get("locationId");
        if (focusLocationId && markerMap[focusLocationId]) {
            const target = locations.find((item) => String(item.id) === String(focusLocationId));
            if (target) {
                const targetZoom = Math.min(Math.max(map.getMinZoom() + 1.1, 1), map.getMaxZoom());
                map.flyTo([target.map_y, target.map_x], targetZoom, { duration: 0.8 });
                markerMap[focusLocationId].openPopup();
                showHighlight([target.map_y, target.map_x], markerMap[focusLocationId], 60);
            }
        }

        /* sidebar render */

        const list = document.getElementById("animalList")
        const searchInput = document.getElementById("search")
        const filterButtons = Array.from(document.querySelectorAll(".quick-filter-btn[data-filter]"));
        const missionFilterBtn = document.getElementById("missionFilterBtn");
        const openBadgesBtn = document.getElementById("openBadgesBtn");
        const badgeModal = document.getElementById("badgeModal");
        const closeBadgeModalBtn = document.getElementById("closeBadgeModalBtn");
        const badgeList = document.getElementById("badgeList");
        const badgeSummary = document.getElementById("badgeSummary");
        const rewardPopup = document.getElementById("rewardPopup");
        const rewardPopupList = document.getElementById("rewardPopupList");
        const closeRewardPopupBtn = document.getElementById("closeRewardPopupBtn");
        const gameCompleteModal = document.getElementById("gameCompleteModal");
        const closeGameCompleteBtn = document.getElementById("closeGameCompleteBtn");
        const routePanel = document.getElementById("routePanel");
        const routePanelTitle = document.getElementById("routePanelTitle");
        const routePanelSubtitle = document.getElementById("routePanelSubtitle");
        const routePanelMeta = document.getElementById("routePanelMeta");
        const routeSteps = document.getElementById("routeSteps");
        const closeRoutePanelBtn = document.getElementById("closeRoutePanelBtn");
        let activeQuickFilter = "all";
        let hasShownGameCompletePopup = false;

        function getMissionCheckedCount() {
            return missionAnimals.reduce((total, animal) => {
                return total + (parseCheckinStatus(animal.checkin_status) ? 1 : 0);
            }, 0);
        }

        function updateMissionFilterLabel() {
            if (!missionFilterBtn) return;
            missionFilterBtn.textContent = `Nhiệm vụ (${getMissionCheckedCount()}/${missionAnimals.length})`;
        }

        function updateBadgeButtonLabel() {
            if (!openBadgesBtn) return;
            openBadgesBtn.textContent = `Huy hiệu (${earnedBadgeIds.size})`;
        }

        function renderBadgeList() {
            if (!badgeList) return;

            const totalBadges = badgeCatalog.length;
            const unlockedBadges = earnedBadgeIds.size;
            const lockedBadges = Math.max(0, totalBadges - unlockedBadges);
            const missionChecked = getMissionCheckedCount();
            const missionTotal = missionAnimals.length;

            if (badgeSummary) {
                badgeSummary.innerHTML = `
<span class="badge-summary-chip">Đã nhận ${unlockedBadges}/${totalBadges}</span>
<span class="badge-summary-chip">Chưa nhận ${lockedBadges}</span>
<span class="badge-summary-chip">Nhiệm vụ ${missionChecked}/${missionTotal}</span>
`;
            }

            badgeList.innerHTML = "";
            badgeCatalog.forEach((badge) => {
                const unlocked = earnedBadgeIds.has(badge.id);
                const badgeIcon = unlocked ? "🏅" : "🔒";
                const row = document.createElement("div");
                row.className = `badge-item ${unlocked ? "unlocked" : "locked"}`;
                row.innerHTML = `
<div class="badge-item-main">
<span class="badge-item-icon" aria-hidden="true">${badgeIcon}</span>
<div>
<div class="badge-item-name">${badge.name}</div>
<div class="badge-item-desc">${badge.description}</div>
</div>
</div>
<span class="badge-item-state">${unlocked ? "Đã nhận" : "Chưa nhận"}</span>
`;
                badgeList.appendChild(row);
            });
        }

        function showRewardPopup(newBadgeIds) {
            if (!rewardPopup || !rewardPopupList || !newBadgeIds.length) return;

            rewardPopupList.innerHTML = "";
            newBadgeIds.forEach((badgeId) => {
                const badge = badgeCatalog.find((item) => item.id === badgeId);
                if (!badge) return;

                const item = document.createElement("li");
                item.textContent = badge.name;
                rewardPopupList.appendChild(item);
            });

            rewardPopup.classList.add("open");
        }

        function hideRewardPopup() {
            if (!rewardPopup) return;
            rewardPopup.classList.remove("open");
        }

        function showGameCompletePopup() {
            if (!gameCompleteModal) return;
            gameCompleteModal.classList.add("open");
            gameCompleteModal.setAttribute("aria-hidden", "false");
        }

        function hideGameCompletePopup() {
            if (!gameCompleteModal) return;
            gameCompleteModal.classList.remove("open");
            gameCompleteModal.setAttribute("aria-hidden", "true");
        }

        function calculateCompletedZones() {
            const checkedByZone = new Map();

            missionAnimals.forEach((animal) => {
                const zone = resolveZoneValue(animal);
                if (typeof zone !== "number") return;

                const checked = parseCheckinStatus(animal.checkin_status);
                if (!checked) return;

                checkedByZone.set(zone, (checkedByZone.get(zone) || 0) + 1);
            });

            const completedZones = new Set();
            for (let zone = 1; zone <= 6; zone += 1) {
                if ((checkedByZone.get(zone) || 0) >= 2) {
                    completedZones.add(zone);
                }
            }

            return completedZones;
        }

        function evaluateAndAwardBadges(showPopup = false) {
            const completedZones = calculateCompletedZones();
            const recalculatedBadgeIds = new Set();

            completedZones.forEach((zone) => {
                recalculatedBadgeIds.add(`zone-${zone}`);
            });

            if (completedZones.size === 6) {
                recalculatedBadgeIds.add("all-zones");
            }

            const newlyAwarded = Array.from(recalculatedBadgeIds).filter(
                (badgeId) => !earnedBadgeIds.has(badgeId),
            );

            earnedBadgeIds.clear();
            recalculatedBadgeIds.forEach((badgeId) => earnedBadgeIds.add(badgeId));

            updateBadgeButtonLabel();
            renderBadgeList();

            if (showPopup && newlyAwarded.length) {
                showRewardPopup(newlyAwarded);
            }
        }

        function findAnimalById(id) {
            return animals.find((item) => String(item.id) === String(id));
        }

        function refreshPopupIfOpen(id) {
            const marker = markerMap[id];
            const record = findAnimalById(id);
            if (!marker || !record) return;

            marker.setPopupContent(buildAnimalPopup(record));
            if (marker.isPopupOpen()) {
                marker.openPopup();
            }
        }

        async function checkinAnimalById(id) {
            const record = findAnimalById(id);
            if (!record) return;

            if (parseCheckinStatus(record.checkin_status)) {
                return;
            }

            try {
                const missionCheckedBefore = getMissionCheckedCount();

                const response = await fetch(`/api/map/animals/${id}/checkin`, {
                    method: "PATCH",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({ checkin_status: true }),
                });

                if (!response.ok) {
                    throw new Error("Không thể check-in lúc này.");
                }

                record.checkin_status = true;

                const missionRecord = missionAnimals.find((item) => String(item.id) === String(id));
                if (missionRecord) missionRecord.checkin_status = true;

                refreshPopupIfOpen(id);
                updateMissionFilterLabel();
                evaluateAndAwardBadges(true);
                applyFiltersAndRender();

                const missionCheckedAfter = getMissionCheckedCount();
                const missionTotal = missionAnimals.length;
                if (!hasShownGameCompletePopup && missionCheckedBefore < missionTotal && missionCheckedAfter === missionTotal && missionTotal > 0) {
                    hasShownGameCompletePopup = true;
                    showGameCompletePopup();
                }
            } catch (error) {
                window.alert(error.message || "Đã có lỗi khi check-in.");
            }
        }

        function renderList(data) {

            list.innerHTML = ""

            if (!data.length) {
                list.innerHTML = `<div class="empty-state">Khong tim thay ket qua phu hop.</div>`;
                return;
            }

            data.forEach(a => {

                const item = document.createElement("div")
                item.className = "animal-item"

                if (a.kind === "location") {
                    const categoryLabel = getLocationCategoryLabel(a.category);
                    item.innerHTML = `
<span class="animal-icon">${locationIcon(a.type)}</span>
<div class="animal-main">
<div class="animal-name">${a.name}</div>
<div class="animal-meta">
<span class="mini-badge cat-${a.category || "utility"}">${categoryLabel}</span>
<span class="mini-badge">${a.type || "Địa điểm"}</span>
</div>
</div>
`;
                } else {
                    const zone = formatZoneLabel(a);
                    const zoneClass = getZoneClassName(a);
                    const active = isAnimalActive(a.status);
                    const statusClass = active ? "status-on" : "status-off";
                    const statusText = active ? "Đang hoạt động" : "Đang nghỉ";
                    const isChecked = parseCheckinStatus(a.checkin_status);
                    const checkinClass = isChecked ? "checkin-on" : "checkin-off";

                    item.innerHTML = `
<span class="animal-icon">${animalIcon(a.species).options.html}</span>
<div class="animal-main">
<div class="animal-name">${a.name}</div>
<div class="animal-meta">
<span class="mini-badge ${zoneClass}">${zone}</span>
<span class="mini-badge ${statusClass}">${statusText}</span>
<span class="mini-badge ${checkinClass}">${getCheckinLabel(isChecked)}</span>
</div>
</div>
`;
                }

               item.onclick = () => {
                    const marker = markerMap[a.id];

                    // 1. Lướt đến vị trí với mức zoom = 1 (hoặc thay bằng map.getZoom() nếu bạn muốn giữ nguyên mức zoom hiện tại không bị giật vào trong)
                    map.flyTo([a.map_y, a.map_x], 1, {
                        animate: true,
                        duration: 1.2 // Lướt đi trong 1.2 giây
                    });

                    // 2. Lắng nghe sự kiện: Đợi bản đồ dừng hẳn hiệu ứng lướt thì mới mở Popup
                    map.once('moveend', () => {
                        marker.openPopup();
                    });
                };
                list.appendChild(item)

            })

        }

        function applyFiltersAndRender() {
            const keyword = String(searchInput?.value || "").trim().toLowerCase();
            const combinedItems = getCombinedItems();

            let baseItems = combinedItems;
            if (activeQuickFilter === "animal") {
                baseItems = combinedItems.filter((item) => item.kind === "animal");
            } else if (activeQuickFilter === "mission") {
                const missionIdSet = new Set(missionAnimals.map((item) => String(item.id)));
                baseItems = combinedItems.filter(
                    (item) => item.kind === "animal" && missionIdSet.has(String(item.id)),
                );
            } else if (["historical", "toilet", "food", "parking", "utility"].includes(activeQuickFilter)) {
                baseItems = combinedItems.filter(
                    (item) => item.kind === "location" && item.category === activeQuickFilter,
                );
            }

            const filtered = baseItems.filter((item) => {
                if (!keyword) return true;

                if (item.kind === "location") {
                    const locationText = [
                        item.name,
                        item.type,
                        item.summary,
                        item.history,
                        item.value,
                        item.experience,
                        item.visit,
                        String(item.map_x),
                        String(item.map_y),
                    ]
                        .filter(Boolean)
                        .join(" ")
                        .toLowerCase();

                    return locationText.includes(keyword);
                }

                return String(item.name || "").toLowerCase().includes(keyword);
            });

            renderList(filtered);
        }

        filterButtons.forEach((btn) => {
            btn.addEventListener("click", () => {
                activeQuickFilter = btn.dataset.filter || "all";

                filterButtons.forEach((button) => {
                    button.classList.toggle("active", button === btn);
                });

                applyFiltersAndRender();
            });
        });

        openBadgesBtn?.addEventListener("click", () => {
            badgeModal?.classList.add("open");
            badgeModal?.setAttribute("aria-hidden", "false");
        });

        closeBadgeModalBtn?.addEventListener("click", () => {
            badgeModal?.classList.remove("open");
            badgeModal?.setAttribute("aria-hidden", "true");
        });

        badgeModal?.addEventListener("click", (event) => {
            if (event.target === badgeModal) {
                badgeModal.classList.remove("open");
                badgeModal.setAttribute("aria-hidden", "true");
            }
        });

        closeRewardPopupBtn?.addEventListener("click", () => {
            hideRewardPopup();
        });

        closeGameCompleteBtn?.addEventListener("click", () => {
            hideGameCompletePopup();
        });

        closeRoutePanelBtn?.addEventListener("click", () => {
            closeRoutePanel();
        });

        gameCompleteModal?.addEventListener("click", (event) => {
            if (event.target === gameCompleteModal) {
                hideGameCompletePopup();
            }
        });

        evaluateAndAwardBadges(false);
        updateMissionFilterLabel();
        updateBadgeButtonLabel();
        renderBadgeList();

        applyFiltersAndRender();

        /* search */

        document
            .getElementById("search")
            .addEventListener("input", e => {
                applyFiltersAndRender()

            })
        
          
    </script>

    <script src="shared-nav.js"></script>

</body>

</html>