        function openRoutePanel(routeConfig) {
            if (!routeConfig || !routePanel || !routePanelTitle || !routePanelSubtitle || !routePanelMeta || !routeSteps) {
                return;
            }

            routePanelTitle.textContent = routeConfig.title || "Chi tiết";
            const avatarHtml = routeConfig.avatarImage
                ? `<span class="route-animal-avatar"><img src="${routeConfig.avatarImage}" alt="${routeConfig.subtitle || "Báo hoa mai"}"></span>`
                : '<span class="route-animal-avatar" aria-hidden="true">🐆</span>';

            routePanelSubtitle.innerHTML = `${avatarHtml}<span>${routeConfig.subtitle || ""}</span>`;

            routePanelMeta.innerHTML = `
<span class="route-meta-chip"><span class="route-meta-icon">${routeSvgIcon("distance")}</span>${routeConfig.totalDistance || ""}</span>
<span class="route-meta-chip"><span class="route-meta-icon">${routeSvgIcon("time")}</span>${routeConfig.totalTime || ""}</span>
`;

            routeSteps.innerHTML = "";
            (routeConfig.steps || []).forEach((step, index) => {
                const row = document.createElement("li");
                row.className = "route-step";

                const distanceChip = step.distance
                    ? `<span class="route-step-meta-chip">${routeSvgIcon("distance")}${step.distance}</span>`
                    : "";
                const timeChip = step.time
                    ? `<span class="route-step-meta-chip">${routeSvgIcon("time")}${step.time}</span>`
                    : "";
                const stepIconName = step.iconType || "straight";
                row.style.animationDelay = `${index * 90}ms`;

                row.innerHTML = `
<span class="route-step-icon">${routeSvgIcon(stepIconName)}</span>
<div class="route-step-main">
<div class="route-step-title">${step.title || ""}</div>
${step.subtitle ? `<div class="route-step-sub">${step.subtitle}</div>` : ""}
</div>
${distanceChip || timeChip ? `<div class="route-step-meta">${distanceChip}${timeChip}</div>` : ""}
`;

                routeSteps.appendChild(row);
            });

            routePanel.classList.add("open");
            routePanel.setAttribute("aria-hidden", "false");
        }

        function closeRoutePanel() {
            if (!routePanel) return;
            routePanel.classList.remove("open");
