            const source = record && typeof record === "object" ? record : {};
            const normalizedKeys = {};

            Object.keys(source).forEach((key) => {
                normalizedKeys[String(key).trim().toLowerCase()] = source[key];
            });

            const zoneValue =
                source.zone ??
                source.Zone ??
                source.zone_id ??
                source.zoneId ??
                source.khu ??
                normalizedKeys.zone ??
                normalizedKeys.zone_id ??
                normalizedKeys.zoneid ??
                normalizedKeys.khu;

            const zoneLabelValue =
                source.zoneLabel ??
                source.zone_label ??
                normalizedKeys.zonelabel ??
                normalizedKeys.zone_label;

            const statusValue =
                source.status ??
                source.Status ??
                normalizedKeys.status;

            const mapX =
                source.map_x ??
                source.mapX ??
                normalizedKeys.map_x ??
                normalizedKeys.mapx;

            const mapY =
                source.map_y ??
                source.mapY ??
                normalizedKeys.map_y ??
                normalizedKeys.mapy;

            const checkinStatus =
                source.checkin_status ??
                source.checkinStatus ??
                normalizedKeys.checkin_status ??
                normalizedKeys.checkinstatus;

            return {
                ...source,
                zone: zoneValue,
                zoneLabel: zoneLabelValue,
                status: statusValue,
                map_x: Number(mapX),
                map_y: Number(mapY),
                checkin_status: parseCheckinStatus(checkinStatus),
            };
