<!DOCTYPE html>
<html>

<head>

    <meta charset="utf-8">

    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

    <style>
        /* layout */

        html,
        body {
            margin: 0;
            height: 100%;
            font-family: Arial;
        }

        #map {
            position: fixed;
            top: 0;
            left: 300px;
            right: 0;
            bottom: 0;
        }

        /* sidebar */
        /* Sidebar hiện đại hơn */
.sidebar {
    position: fixed;
    left: 0; top: 0; bottom: 0;
    width: 300px;
    background: #ffffff;
    box-shadow: 4px 0 15px rgba(0, 0, 0, 0.1);
    z-index: 1000;
    display: flex;
    flex-direction: column;
}

.sidebar-header {
    padding: 25px 20px;
    font-size: 22px;
    color: #2c3e50;
    background: #f8f9fa;
    border-bottom: 2px solid #eee;
}

.animal-item {
    padding: 12px 15px;
    margin: 8px 12px;
    border-radius: 12px;
    transition: all 0.3s ease; /* Tạo hiệu ứng mượt */
    border: 1px solid transparent;
}

.animal-item:hover {
    background: #e3f2fd;
    transform: translateX(5px);
    border-color: #2196f3;
}

/* Tùy chỉnh thanh cuộn cho đẹp */
.sidebar::-webkit-scrollbar {
    width: 6px;
}
.sidebar::-webkit-scrollbar-thumb {
    background: #ccc;
    border-radius: 10px;
}
        .sidebar {
            position: fixed;
            left: 0;
            top: 0;
            bottom: 0;
            width: 300px;
            background: white;
            box-shadow: 2px 0 10px rgba(0, 0, 0, 0.2);
            z-index: 1000;
            overflow: auto;
        }

        .sidebar-header {
            padding: 15px;
            font-size: 20px;
            font-weight: bold;
            border-bottom: 1px solid #ddd;
        }

        .search-box {
            padding: 10px;
        }

        .search-box input {
            width: 100%;
            padding: 8px;
            border-radius: 6px;
            border: 1px solid #ccc;
        }

        .animal-list {
            padding: 10px;
        }

        .animal-item {
            padding: 8px;
            border-radius: 6px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .animal-item:hover {
            background: #f0f0f0;
        }

        /* popup */

        .popup-card {
            width: 220px;
        }

        .popup-img {
            width: 100%;
            height: 120px;
            object-fit: cover;
            border-radius: 6px;
            margin-bottom: 6px;
        }

        .popup-title {
            font-weight: bold;
        }

        .popup-status {
            font-size: 13px;
            color: #555;
        }
    </style>

</head>

<body>

    <div class="sidebar">

        <div class="sidebar-header">
            Thảo Cầm Viên
        </div>

        <div class="search-box">
            <input id="search" placeholder="Search animal...">
        </div>

        <div class="animal-list" id="animalList">
        </div>

    </div>

    <div id="map"></div>

    <script>

        /* map setup */

     /* map setup */
       /* map setup */
        const width = 2000;
        const height = 1100;
        const bounds = [[0, 0], [height, width]];

        // Khởi tạo map, tạm thời chưa set minZoom
        const map = L.map("map", {
            crs: L.CRS.Simple,
            maxZoom: 2,
            zoomSnap: 0.1, // Bắt buộc phải có để mức zoom tính toán (số lẻ) hoạt động mượt
            maxBounds: bounds,
            maxBoundsViscosity: 1.0 // Không cho kéo nảy ra ngoài viền ảnh
        });

        L.imageOverlay("/assets1/zoo2.jpg", bounds).addTo(map);

        // Hàm tự động tính toán minZoom để ảnh luôn FULL khung bên phải
        function updateMinZoom() {
            const mapContainer = document.getElementById("map");

            // Tính tỷ lệ giữa khung chứa bản đồ và kích thước thật của ảnh
            const scaleX = mapContainer.clientWidth / width;
            const scaleY = mapContainer.clientHeight / height;

            // Math.max giúp ảnh luôn phủ kín viền (cover). 
            // Không bao giờ để lộ khoảng trắng dù màn hình tỷ lệ nào.
            const scale = Math.max(scaleX, scaleY);

            // Đổi từ tỷ lệ (scale) sang mức zoom của Leaflet (hệ số logarit cơ số 2)
            const minZoom = Math.log2(scale);

            // Cập nhật minZoom mới cho bản đồ
            map.setMinZoom(minZoom);
        }

        // Chạy hàm tính toán khi vừa load trang
        updateMinZoom();

        // Căn giữa bản đồ ở mức zoom nhỏ nhất vừa tính toán
        map.setView([height / 2, width / 2], map.getMinZoom());

        // Tự động tính toán lại nếu người dùng thay đổi kích thước cửa sổ trình duyệt
        window.addEventListener("resize", () => {
            updateMinZoom();
        });

        /* animals */

        const animals = {{{ animals }}}

        /* icon function */

        function animalIcon(type) {

            let icon = "🐾"

            if (type?.toLowerCase().includes("tiger")) icon = "🐯"
            else if (type?.toLowerCase().includes("elephant")) icon = "🐘"
            else if (type?.toLowerCase().includes("giraffe")) icon = "🦒"
            else if (type?.toLowerCase().includes("lion")) icon = "🦁"
            else if (type?.toLowerCase().includes("bird")) icon = "🦜"

            return L.divIcon({
                html: `<div style="font-size:28px">${icon}</div>`,
                iconSize: [1, 1],
                className: "animal-marker"
            })

        }

        /* markers */

        const markerMap = {}

        let highlightCircle

        animals.forEach(a => {

            const marker = L.marker(
                [a.map_y, a.map_x],
                { opacity: 0 }   // 👈 ẩn hoàn toàn
            ).addTo(map)

            markerMap[a.id] = marker

            /* hover highlight */

            marker.on("mouseover", () => {

                if (highlightCircle) map.removeLayer(highlightCircle)

                highlightCircle = L.circle(
                    [a.map_y, a.map_x],
                    {
                        radius: 40,
                        color: "#00aaff",
                        weight: 2,
                        fillOpacity: 0.2
                    }
                ).addTo(map)

            })

            marker.on("mouseout", () => {
                if (highlightCircle) map.removeLayer(highlightCircle)
            })

            /* popup */

            marker.bindPopup(`

<div class="popup-card">

<img class="popup-img"
src="${a.image_url || '/images/animal.jpg'}">

<div class="popup-title">
${a.name}
</div>

<div class="popup-status">
Species: ${a.species || "unknown"}<br>
Status: ${a.status || "normal"}
</div>

</div>

`)

        })

        /* sidebar render */

        const list = document.getElementById("animalList")

        function renderList(data) {

            list.innerHTML = ""

            data.forEach(a => {

                const item = document.createElement("div")
                item.className = "animal-item"

                item.innerHTML = `
<span style="font-size:20px">
${animalIcon(a.species).options.html}
</span>
${a.name}
`

               item.onclick = () => {
                    const marker = markerMap[a.id];

                    // 1. Lướt đến vị trí với mức zoom = 1 (hoặc thay bằng map.getZoom() nếu bạn muốn giữ nguyên mức zoom hiện tại không bị giật vào trong)
                    map.flyTo([a.map_y, a.map_x], 1, {
                        animate: true,
                        duration: 1.2 // Lướt đi trong 1.2 giây
                    });

                    // 2. Lắng nghe sự kiện: Đợi bản đồ dừng hẳn hiệu ứng lướt thì mới mở Popup
                    map.once('moveend', () => {
                        marker.openPopup();
                    });
                };
                list.appendChild(item)

            })

        }

        renderList(animals)

        /* search */

        document
            .getElementById("search")
            .addEventListener("input", e => {

                const keyword = e.target.value.toLowerCase()

                const filtered = animals.filter(a =>
                    a.name.toLowerCase().includes(keyword)
                )

                renderList(filtered)

            })


    map.on("click", function (e) {
            const x = e.latlng.lng;
            const y = e.latlng.lat;

            console.log("X:", x, "Y:", y);

            // Hiển thị trực tiếp trên map
            L.popup()
                .setLatLng(e.latlng)
                .setContent(`X: ${x.toFixed(0)}, Y: ${y.toFixed(0)}`)
                .openOn(map);
        });    
    </script>

</body>

</html>